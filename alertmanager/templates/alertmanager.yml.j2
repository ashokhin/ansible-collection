{{ ansible_managed | comment }}

route:
  {{ alertmanager_route | to_nice_yaml(indent=2) | indent(2, False) }}

templates:
{% for path in alertmanager_message_templates_paths %}
  - '{{ path }}/*'
{% endfor %}
{% if alertmanager_receivers | length %}

receivers:
  {{ alertmanager_receivers | to_nice_yaml(indent=2) | regex_replace("(chat_id:) '(-?[0-9]+)'", "\\1 \\2") | indent(2) }}
{% endif %}
{% if alertmanager_inhibit_rules | length %}

inhibit_rules:
  {{ alertmanager_inhibit_rules | to_nice_yaml(indent=2) | indent(2) }}
{% endif %}
